# Makefile for {{PROJECT_NAME}}

.PHONY: help up down build build-prod stop restart clean logs shell migrate test

PROJECT_NAME={{PROJECT_NAME}}
REGISTRY={{REGISTRY}}
TAG?=latest
PLATFORMS=linux/amd64,linux/arm64

help:
	@echo "Usage: make <target>"
	@echo ""
	@echo "Development:"
	@echo "  up              Start development environment"
	@echo "  down            Stop all containers"
	@echo "  build           Build development image"
	@echo "  restart         Restart all containers"
	@echo "  logs            Follow container logs"
	@echo "  shell           Access app container shell"
	@echo ""
	@echo "Laravel:"
	@echo "  migrate         Run database migrations"
	@echo "  migrate-fresh   Fresh migration (destroys data)"
	@echo "  seed            Run database seeders"
	@echo "  test            Run tests"
	@echo "  cache-clear     Clear all Laravel caches"
	@echo ""
	@echo "Production:"
	@echo "  build-prod      Build production image (multiarch)"
	@echo "  build-local     Build production image (local arch)"
	@echo "  run-prod        Start production environment"
	@echo "  push            Push image to registry"

# === Development ===

up:
	docker compose up -d
	@echo "Development environment started!"
	@echo "  App:        http://localhost:$${NGINX_PORT:-8080}"
	@echo "  phpMyAdmin: http://localhost:$${PMA_PORT:-8081}"
	@echo "  Mailhog:    http://localhost:$${MAILHOG_PORT:-8025}"

down:
	docker compose down

build:
	docker compose build app

restart:
	docker compose restart

stop: down

clean:
	docker compose down -v
	@echo "Containers and volumes removed."

# === Logs & Shell ===

logs:
	docker compose logs -f

logs-app:
	docker compose logs -f app

shell:
	docker compose exec app bash

# === Laravel Commands ===

migrate:
	docker compose exec app php artisan migrate --force

migrate-fresh:
	docker compose exec app php artisan migrate:fresh --force

seed:
	docker compose exec app php artisan db:seed --force

test:
	docker compose exec app php artisan test

cache-clear:
	docker compose exec app php artisan cache:clear
	docker compose exec app php artisan config:clear
	docker compose exec app php artisan route:clear
	docker compose exec app php artisan view:clear

cache-optimize:
	docker compose exec app php artisan config:cache
	docker compose exec app php artisan route:cache
	docker compose exec app php artisan view:cache

# === Composer & npm ===

composer-install:
	docker compose exec app composer install

npm-install:
	docker compose exec app npm install

npm-dev:
	docker compose exec app npm run dev

npm-build:
	docker compose exec app npm run build

# === Production ===

build-prod:
	docker buildx create --use --name $(PROJECT_NAME)-builder 2>/dev/null || docker buildx use $(PROJECT_NAME)-builder
	docker buildx build \
		--platform $(PLATFORMS) \
		--file Dockerfile.prod \
		--tag $(REGISTRY)/$(PROJECT_NAME):$(TAG) \
		--tag $(REGISTRY)/$(PROJECT_NAME):latest \
		--push .

build-local:
	docker build -f Dockerfile.prod -t $(REGISTRY)/$(PROJECT_NAME):$(TAG) .

run-prod:
	docker compose -f docker-compose.prod.yml up -d

push:
	docker push $(REGISTRY)/$(PROJECT_NAME):$(TAG)
	docker push $(REGISTRY)/$(PROJECT_NAME):latest

# === Init (first-time setup) ===

init:
	@test -f .env || cp .env.docker .env && echo ".env created from template"
	docker compose build
	docker compose up -d
	@echo "Waiting for services..."
	@sleep 15
	docker compose exec app composer install
	docker compose exec app php artisan key:generate
	docker compose exec app php artisan migrate --force
	docker compose exec app php artisan storage:link
	@echo "Done! Access at http://localhost:$${NGINX_PORT:-8080}"
