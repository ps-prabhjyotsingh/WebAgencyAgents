# Production Dockerfile for Laravel (Multi-stage)
# PHP Version: {{PHP_VERSION}}

# Stage 1: Build Dependencies & Assets
FROM ubuntu:22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

WORKDIR /var/www/html

RUN apt-get update && apt-get install -y \
    software-properties-common ca-certificates \
    && LC_ALL=C.UTF-8 add-apt-repository -y ppa:ondrej/php \
    && apt-get update \
    && apt-get install -y \
    php{{PHP_VERSION}}-cli php{{PHP_VERSION}}-common php{{PHP_VERSION}}-zip \
    php{{PHP_VERSION}}-mbstring php{{PHP_VERSION}}-xml php{{PHP_VERSION}}-curl \
    git unzip curl \
    && rm -rf /var/lib/apt/lists/*

{{NODE_BUILD_SECTION_START}}
RUN curl -fsSL https://deb.nodesource.com/setup_{{NODE_VERSION}}.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*
{{NODE_BUILD_SECTION_END}}

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

COPY composer.json composer.lock ./
RUN composer install --no-dev --no-scripts --no-autoloader --no-interaction --prefer-dist

{{NODE_BUILD_ASSETS_START}}
COPY package.json package-lock.json* ./
RUN npm ci
COPY vite.config.js vite.config.ts* webpack.mix.js* ./
COPY resources/ resources/
COPY public/ public/
RUN npm run build
{{NODE_BUILD_ASSETS_END}}

COPY . .
RUN composer dump-autoload --optimize --classmap-authoritative --no-dev

# Stage 2: Production Runtime
FROM ubuntu:22.04 AS production

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

WORKDIR /var/www/html

RUN apt-get update && apt-get install -y \
    software-properties-common ca-certificates \
    && LC_ALL=C.UTF-8 add-apt-repository -y ppa:ondrej/php \
    && apt-get update \
    && apt-get install -y \
    php{{PHP_VERSION}}-fpm php{{PHP_VERSION}}-cli php{{PHP_VERSION}}-common \
    php{{PHP_VERSION}}-mysql php{{PHP_VERSION}}-pgsql php{{PHP_VERSION}}-zip \
    php{{PHP_VERSION}}-gd php{{PHP_VERSION}}-mbstring php{{PHP_VERSION}}-curl \
    php{{PHP_VERSION}}-xml php{{PHP_VERSION}}-bcmath php{{PHP_VERSION}}-intl \
    php{{PHP_VERSION}}-redis php{{PHP_VERSION}}-opcache \
    curl netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

RUN { \
    echo 'opcache.enable=1'; \
    echo 'opcache.memory_consumption=256'; \
    echo 'opcache.max_accelerated_files=20000'; \
    echo 'opcache.validate_timestamps=0'; \
    echo 'display_errors=Off'; \
    echo 'log_errors=On'; \
    echo 'memory_limit=256M'; \
    echo 'upload_max_filesize=50M'; \
    echo 'post_max_size=50M'; \
    } >> /etc/php/{{PHP_VERSION}}/fpm/php.ini

RUN sed -i 's|listen = /run/php/php{{PHP_VERSION}}-fpm.sock|listen = 9000|' /etc/php/{{PHP_VERSION}}/fpm/pool.d/www.conf \
    && echo 'ping.path = /ping' >> /etc/php/{{PHP_VERSION}}/fpm/pool.d/www.conf \
    && mkdir -p /run/php

COPY --from=builder --chown=www-data:www-data /var/www/html /var/www/html

RUN mkdir -p storage/framework/{cache,sessions,views} storage/logs bootstrap/cache \
    && chown -R www-data:www-data storage bootstrap/cache \
    && chmod -R 775 storage bootstrap/cache

COPY docker/scripts/entrypoint-prod.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

EXPOSE 9000

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD nc -z localhost 9000 || exit 1

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["php-fpm{{PHP_VERSION}}", "--nodaemonize"]
