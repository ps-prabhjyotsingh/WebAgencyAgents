# Docker Environment Configuration for {{PROJECT_NAME}}
# Copy this file to .env and customize as needed

APP_NAME={{PROJECT_NAME}}
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database Configuration (Docker services)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE={{DB_DATABASE}}
DB_USERNAME=root
DB_PASSWORD={{DB_PASSWORD}}

# Cache Configuration (Docker services)
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration (Mailhog for testing)
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@{{PROJECT_NAME}}.local
MAIL_FROM_NAME="${APP_NAME}"

# Ports (customize if needed)
NGINX_PORT=8080
PMA_PORT=8081
MAILHOG_PORT=8025
DB_PORT=3306
REDIS_PORT=6379

# File Upload Limits
MAX_UPLOAD_SIZE=50M

# Additional Laravel Configuration
BROADCAST_DRIVER=log
FILESYSTEM_DRIVER=local
QUEUE_DRIVER=redis

# AWS S3 (if using)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Pusher (if using)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
